      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जमा किए गए विवरण की समीक्षा करें, कोई भी छूटा हुआ प्रमाण फिर से अपलोड करें, और अनुमोदन के लिए दोबारा सबमिट करें।"
