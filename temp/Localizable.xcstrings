        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ನಮ್ಮ ತಂಡವು ನಿಮ್ಮ ಗುರುತು ಮತ್ತು ಆದಾಯವನ್ನು ಯಶಸ್ವಿಯಾಗಿ ಪರಿಶೀಲಿಸಿದೆ."
