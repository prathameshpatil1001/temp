    },
    "Keep your documents handy. The verification screens will resume from the latest available state." : {
      "comment" : "KYC next-step guidance when verification is pending.",
      "extractionState" : "stale",
      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने दस्तावेज़ तैयार रखें। सत्यापन स्क्रीन नवीनतम उपलब्ध चरण से फिर शुरू होंगी।"
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ನಿಮ್ಮ ದಾಖಲೆಗಳನ್ನು ಸಿದ್ಧವಾಗಿಡಿ. ಪರಿಶೀಲನಾ ಪರದೆಗಳು ಇತ್ತೀಚಿನ ಸ್ಥಿತಿಯಿಂದ ಪುನರಾರಂಭವಾಗುತ್ತವೆ."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तुमची कागदपत्रे तयार ठेवा. पडताळणी स्क्रीन उपलब्ध असलेल्या नवीनतम टप्प्यावरून पुन्हा सुरू होतील."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் ஆவணங்களை தயார் வைத்திருங்கள். சரிபார்ப்பு திரைகள் சமீபத்திய நிலைமையிலிருந்து மீண்டும் தொடங்கும்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "మీ పత్రాలను సిద్ధంగా ఉంచండి. ధృవీకరణ స్క్రీన్లు తాజా అందుబాటులో ఉన్న దశ నుండి మళ్లీ ప్రారంభమవుతాయి."
          }
        }
      }
    },
    "Keep your face visible while signing. This confirms that you are submitting the onboarding details yourself." : {
      "comment" : "A description under the header that explains the purpose of the e-signature.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हस्ताक्षर करते समय अपना चेहरा दिखाई देता रखें। इससे पुष्टि होती है कि आप स्वयं ऑनबोर्डिंग विवरण जमा कर रहे हैं।"
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep your face visible while signing. This confirms that you are submitting the onboarding details yourself."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सही करताना तुमचा चेहरा दिसेल याची खात्री करा. यामुळे ऑनबोर्डिंग तपशील तुम्ही स्वतः सादर करत आहात हे निश्चित होते."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "கையொப்பமிடும் போது உங்கள் முகம் தெளிவாகத் தெரிவிக்கட்டும். இதனால் onboarding விவரங்களை நீங்களே சமர்ப்பிக்கிறீர்கள் என்பதை உறுதிப்படுத்துகிறது."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "సంతకం చేసే సమయంలో మీ ముఖం కనిపించేలా ఉంచండి. దీని ద్వారా onboarding వివరాలను మీరు స్వయంగా సమర్పిస్తున్నారని నిర్ధారిస్తుంది."
          }
        }
      }
    },
