    "Never miss an EMI. Automate your payments safely." : {
      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कभी EMI न चूकें। अपने भुगतान सुरक्षित रूप से स्वचालित करें।"
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ಯಾವ EMIಯನ್ನೂ ತಪ್ಪಿಸಬೇಡಿ. ನಿಮ್ಮ ಪಾವತಿಗಳನ್ನು ಸುರಕ್ಷಿತವಾಗಿ ಸ್ವಯಂಚಾಲಿತಗೊಳಿಸಿ."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EMI कधीही चुकवू नका. तुमची पेमेंट्स सुरक्षितपणे ऑटोमेट करा."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ஒரு EMIயும் தவறவிடாதீர்கள். உங்கள் கட்டணங்களை பாதுகாப்பாக தானியக்கப்படுத்துங்கள்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ఒక EMI కూడా మిస్ కావద్దు. మీ చెల్లింపులను సురక్షితంగా ఆటోమేట్ చేయండి."
          }
        }
      }
    },
