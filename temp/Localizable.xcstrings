        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ಯಾವುದೇ ಗೂಢ ಶುಲ್ಕಗಳಿಲ್ಲ. ಅಂತಿಮ ಪರಿಶೀಲನೆಯ ನಂತರ ತಕ್ಷಣದ ವಿತರಣೆ."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "लपलेले शुल्क नाहीत. अंतिम पडताळणीनंतर त्वरित वितरण."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "மறைமுக கட்டணங்கள் இல்லை. இறுதி சரிபார்ப்புக்குப் பிறகு உடனடி வழங்கல்."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "దాచిన ఛార్జీలు లేవు. తుది ధృవీకరణ తర్వాత వెంటనే విడుదల."
          }
        }
      }
